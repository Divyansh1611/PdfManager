@{
    Layout = null;
    ViewData["Title"] = "PDF Viewer";
    var fileName = ViewBag.FileName as string;
}

<!DOCTYPE html>
<html>
<head>
    <title>PDF Viewer</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css"
          rel="stylesheet">
    <style>
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            background: #1a1a2e;
            color: white;
            font-family: 'Segoe UI', sans-serif;
        }

        .top-bar {
            background: #16213e;
            padding: 12px 24px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            border-bottom: 2px solid #0d6efd;
            position: sticky;
            top: 0;
            z-index: 100;
        }

            .top-bar .title {
                font-size: 18px;
                font-weight: bold;
                color: #4dabf7;
            }

            .top-bar .filename {
                font-size: 12px;
                color: #868e96;
                margin-left: 12px;
            }

        .pdf-container {
            display: flex;
            flex-direction: column;
            align-items: center;
            padding: 24px 16px;
            min-height: calc(100vh - 60px - 70px);
        }

        .loading-msg {
            color: #4dabf7;
            font-size: 18px;
            margin: 60px 0;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .controls {
            display: flex;
            align-items: center;
            gap: 10px;
            margin: 16px 0;
            background: #16213e;
            padding: 10px 20px;
            border-radius: 50px;
            border: 1px solid #0d6efd;
            flex-wrap: wrap;
            justify-content: center;
        }

            .controls button {
                border: none;
                background: #0d6efd;
                color: white;
                border-radius: 8px;
                padding: 6px 14px;
                cursor: pointer;
                font-weight: bold;
                font-size: 13px;
                transition: 0.2s;
            }

                .controls button:hover {
                    background: #0a58ca;
                }

                .controls button:disabled {
                    background: #333;
                    color: #666;
                    cursor: not-allowed;
                }

        #pageInfo {
            font-size: 14px;
            color: #adb5bd;
            white-space: nowrap;
        }

        #jumpPage {
            width: 75px;
            padding: 5px 8px;
            border-radius: 6px;
            border: 1px solid #0d6efd;
            background: #1a1a2e;
            color: white;
            text-align: center;
            font-size: 13px;
        }

        #pdfCanvas {
            border: 2px solid #0d6efd;
            border-radius: 8px;
            box-shadow: 0 8px 32px rgba(0,0,0,0.5);
            max-width: 100%;
            background: white;
            display: block;
        }

        #zoomInfo {
            color: #adb5bd;
            font-size: 13px;
            min-width: 45px;
            text-align: center;
        }

        .action-bar {
            background: #16213e;
            padding: 14px 24px;
            border-top: 2px solid #0d6efd;
            display: flex;
            gap: 12px;
            justify-content: center;
            flex-wrap: wrap;
            position: sticky;
            bottom: 0;
        }
    </style>
</head>
<body>

    <!-- Top Bar -->
    <div class="top-bar">
        <div style="display:flex; align-items:center">
            <span class="title">📄 PDF Manager</span>
            <span class="filename">@fileName</span>
        </div>
        <a href="/Pdf/Index" class="btn btn-sm btn-outline-light">
            ⬆️ Upload New PDF
        </a>
    </div>

    <!-- PDF Area -->
    <div class="pdf-container">

        <!-- Loading -->
        <div class="loading-msg" id="loadingMsg">
            ⏳ Loading PDF...
        </div>

        <!-- Page Controls -->
        <div class="controls" id="pageControls" style="display:none">
            <button id="firstBtn" onclick="goToPage(1)">⏮ First</button>
            <button id="prevBtn" onclick="changePage(-1)">◀ Prev</button>
            <span id="pageInfo">Page 1 of 1</span>
            <button id="nextBtn" onclick="changePage(1)">Next ▶</button>
            <button id="lastBtn">Last ⏭</button>
            <input type="number" id="jumpPage" min="1" placeholder="Go to..">
            <button onclick="jumpToPage()">Go</button>
        </div>

        <!-- Canvas -->
        <canvas id="pdfCanvas"></canvas>

        <!-- Zoom Controls -->
        <div class="controls mt-3" id="zoomControls" style="display:none">
            <button onclick="changeZoom(-0.25)">🔍 Zoom Out</button>
            <span id="zoomInfo">150%</span>
            <button onclick="changeZoom(0.25)">🔍 Zoom In</button>
            <button onclick="resetZoom()">↺ Reset</button>
        </div>

    </div>

    <!-- Action Bar -->
    <div class="action-bar">
        <a href="/Pdf/Index" class="btn btn-outline-light">
            ⬆️ Upload New
        </a>
        <button class="btn btn-primary"
                onclick="window.location='/Pdf/Extract'">
            ✂️ Extract Pages
        </button>
        <button class="btn btn-success"
                onclick="screenshotCurrentPage()">
            📸 Screenshot This Page
        </button>
        <button class="btn btn-danger"
                onclick="confirmDelete()">
            🗑️ Delete PDF
        </button>
    </div>

    <!-- PDF.js CDN -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.min.js"></script>

    <script>
        // Worker
        pdfjsLib.GlobalWorkerOptions.workerSrc =
            'https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.worker.min.js';

        // PDF URL
        // const pdfUrl = encodeURI('/uploads/@fileName');
        const pdfUrl = '@ViewBag.PdfUrl';

        let pdfDoc = null;
        let currentPage = 1;
        let totalPages = 0;
        let scale = 1.5;
        let isRendering = false;

        const canvas = document.getElementById('pdfCanvas');
        const ctx = canvas.getContext('2d');

        // Load PDF
        async function loadPdf() {
            try {
                const loadingTask = pdfjsLib.getDocument({
                    url: pdfUrl,
                    cMapUrl: 'https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/cmaps/',
                    cMapPacked: true,
                });

                pdfDoc = await loadingTask.promise;
                totalPages = pdfDoc.numPages;

                document.getElementById('loadingMsg').style.display = 'none';
                document.getElementById('pageControls').style.display = 'flex';
                document.getElementById('zoomControls').style.display = 'flex';
                document.getElementById('lastBtn').onclick = () => goToPage(totalPages);

                await renderPage(currentPage);

            } catch (err) {
                document.getElementById('loadingMsg').textContent =
                    '❌ Error: ' + err.message;
                console.error('PDF Error:', err);
            }
        }

        // Render page
        async function renderPage(pageNum) {
            if (isRendering) return;
            isRendering = true;

            try {
                const page = await pdfDoc.getPage(pageNum);
                const viewport = page.getViewport({ scale: scale });

                canvas.width = viewport.width;
                canvas.height = viewport.height;

                await page.render({
                    canvasContext: ctx,
                    viewport: viewport
                }).promise;

                currentPage = pageNum;
                updateControls();

            } catch (err) {
                console.error('Render error:', err);
            } finally {
                isRendering = false;
            }
        }

        // Update UI controls
        function updateControls() {
            document.getElementById('pageInfo').textContent =
                `Page ${currentPage} of ${totalPages}`;

            document.getElementById('prevBtn').disabled = currentPage <= 1;
            document.getElementById('firstBtn').disabled = currentPage <= 1;
            document.getElementById('nextBtn').disabled = currentPage >= totalPages;
            document.getElementById('lastBtn').disabled = currentPage >= totalPages;

            document.getElementById('zoomInfo').textContent =
                Math.round(scale * 100) + '%';
        }

        function changePage(delta) {
            const newPage = currentPage + delta;
            if (newPage >= 1 && newPage <= totalPages)
                renderPage(newPage);
        }

        function goToPage(pageNum) {
            if (pageNum >= 1 && pageNum <= totalPages)
                renderPage(pageNum);
        }

        function jumpToPage() {
            const input = document.getElementById('jumpPage');
            const pageNum = parseInt(input.value);
            if (pageNum >= 1 && pageNum <= totalPages) {
                renderPage(pageNum);
                input.value = '';
            } else {
                alert(`Please enter page between 1 and ${totalPages}`);
            }
        }

        function changeZoom(delta) {
            scale = Math.max(0.5, Math.min(3.0, scale + delta));
            renderPage(currentPage);
        }

        function resetZoom() {
            scale = 1.5;
            renderPage(currentPage);
        }

        function screenshotCurrentPage() {
            window.location = `/Pdf/Screenshot?pageNum=${currentPage}`;
        }

        // Keyboard nav
        document.addEventListener('keydown', function (e) {
            if (e.key === 'ArrowRight' || e.key === 'ArrowDown') changePage(1);
            if (e.key === 'ArrowLeft' || e.key === 'ArrowUp') changePage(-1);
        });

        function confirmDelete() {
            if (confirm('⚠️ Are you sure you want to delete this PDF?\n\nYeh action undo nahi ho sakta!')) {
                window.location = '/Pdf/Delete';
            }
        }
        // Start!
        loadPdf();
    </script>

</body>
</html>